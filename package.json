{
  "name": "re-member",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasbergernz/re-member.git"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:staging": "DOTENV_CONFIG_PATH=.env.staging.local astro dev",
    "dev:production": "DOTENV_CONFIG_PATH=.env.production.local astro dev",
    "build": "astro build",
    "build:staging": "DOTENV_CONFIG_PATH=.env.staging.local astro build",
    "build:production": "DOTENV_CONFIG_PATH=.env.production.local astro build",
    "preview": "astro preview",
    "preview:staging": "DOTENV_CONFIG_PATH=.env.staging.local astro preview",
    "preview:production": "DOTENV_CONFIG_PATH=.env.production.local astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.3",
    "@sentry/node": "^10.63.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^6.4.4",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "googleapis": "^140.0.0",
    "luxon": "^3.7.2",
    "mailgun.js": "^11.1.0",
    "pino": "^10.3.1",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@types/luxon": "^3.7.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  }
