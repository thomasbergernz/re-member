# ============================================================
# STRIPE ENVIRONMENT NOTES
# ============================================================
# Stripe keys are environment-specific: test keys (sk_test_...) only work with test prices,
# live keys (sk_live_...) only work with live prices. Each Fly app should have its own
# complete set of Stripe variables.
#
# Current apps (example.com fork):
#   Production: acme-production  → live keys + live price IDs + PUBLIC_APP_URL=https://example.com
#   Staging:    acme-staging     → test keys + test price IDs + PUBLIC_APP_URL=https://acme-staging.fly.dev
# Stripe webhook endpoints (configured in Stripe Dashboard/Webhooks):
#   Staging:    https://acme-staging.fly.dev/api/stripe-webhook
#   Production: https://example.com/api/stripe-webhook
#
# Local env file conventions (all ignored by git):
#   .env                    -> default local dev (npm run dev)
#   .env.staging.local      -> local staging profile (npm run dev:staging)
#   .env.production.local   -> local production profile (npm run dev:production)
# ============================================================

# Stripe (server-side only) — use sk_test_... for staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional safety mode for validating Stripe config without creating live checkouts.
# Accepted true values: true, 1, yes, on
CHECKOUT_DRY_RUN=false

# Stripe product prices — these differ between test and live Stripe dashboards.
# Numbering follows tier definition order in src/lib/forms/tiers.ts:
#   1 = basic (associate-equivalent)
#   2 = advanced (professional-equivalent)
#   N = any new tier appended to TIERS — see docs/DEPLOY.md Phase 7.
# Test prices: from Stripe test dashboard
# Live prices: from Stripe live dashboard
STRIPE_PRICE_1=price_replace_me
STRIPE_PRICE_2=price_replace_me
STRIPE_PRICE_1_RENEWAL=price_replace_me
STRIPE_PRICE_2_RENEWAL=price_replace_me


# Public site base URL — MUST match the deployed environment:
#   Local dev:        http://localhost:4321
#   Staging deploy:   https://acme-staging.fly.dev
#   Production deploy: https://example.com
PUBLIC_APP_URL=http://localhost:4321

# Annual renewal cutoff (membership-year anchor). Renewals and the deferred
# subscription's trial_end align to the NEXT occurrence of this month/day.
# Defaults to 1 July (New Zealand financial-year style) if unset. Server-side
# only. Month 1-12, day 1-31 (must be a valid day for that month).
#   Examples: 1 January -> MONTH=1 DAY=1 ; 1 April -> MONTH=4 DAY=1
RENEWAL_ANCHOR_MONTH=7
RENEWAL_ANCHOR_DAY=1

# Org identity (used in email subjects, bodies, From/Reply-To fallbacks)
ORG_NAME=Re:Member
SUPPORT_EMAIL=membership@example.com
ADMIN_EMAIL=admin@example.com
PUBLIC_ORG_URL=https://example.com
# Optional overrides for src/lib/staging.ts fallbacks
# STAGING_APP_URL=https://staging.example.com
# PROD_APP_URL=https://example.com

# Google Sheets / Drive / Docs (service account)
# Create in Google Cloud Console → IAM → Service Accounts → create key → download JSON.
# The same service account reads/writes the applications spreadsheet AND uploads
# applicant documents + review Docs to Drive.
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Domain-Wide Delegation impersonation user (REQUIRED for Drive uploads).
# Service accounts have no Drive storage of their own, so uploads attributed
# directly to the SA fail with 403 storageQuotaExceeded. Set this to a real
# Workspace mailbox the SA impersonates (DWD must be enabled + scopes
# authorized in the Admin Console). See
# docs/runbooks/google-workspace-domain-wide-delegation.md.
GOOGLE_WORKSPACE_IMPERSONATE_USER=it-admin@your-domain.example

# Drive folder IDs (REQUIRED). Parent folder that holds per-applicant document
# subfolders. Review Docs land in REVIEW_DOCS_FOLDER_ID if set, else fall back
# to the applications folder.
GOOGLE_DRIVE_APPLICATIONS_FOLDER_ID=your-drive-folder-id
# Optional: separate folder for auto-generated review Docs.
# GOOGLE_DRIVE_REVIEW_DOCS_FOLDER_ID=your-review-docs-folder-id

# Mailgun transactional email (REQUIRED — sole email provider).
#   MAILGUN_API_KEY — private API key (starts with "key-")
#   MAILGUN_DOMAIN  — verified sending domain (e.g. "mg.example.com").
#                     On a Mailgun sandbox only verified recipients receive mail.
#   MAILGUN_FROM    — full From header value, e.g. "Re:Member <no-reply@mg.example.com>"
# See docs/runbooks/mailgun-setup.md.
MAILGUN_API_KEY=key-replace_me
MAILGUN_DOMAIN=mg.your-domain.example
MAILGUN_FROM=Re:Member <no-reply@mg.your-domain.example>