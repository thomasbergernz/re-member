# ============================================================
# STRIPE ENVIRONMENT NOTES
# ============================================================
# Stripe keys are environment-specific: test keys (sk_test_...) only work with test prices,
# live keys (sk_live_...) only work with live prices. Each Fly app should have its own
# complete set of Stripe variables.
#
# Current apps (rename `remember` to your Fly app name):
#   Production: remember-production  → live keys + live price IDs + PUBLIC_APP_URL=https://your-domain.example
#   Staging:    remember-staging     → test keys + test price IDs + PUBLIC_APP_URL=https://remember-staging.fly.dev
# Stripe webhook endpoints (configured in Stripe Dashboard/Webhooks):
#   Staging:    https://remember-staging.fly.dev/api/stripe-webhook
#   Production: https://your-domain.example/api/stripe-webhook
#
# Local env file conventions (all ignored by git):
#   .env                    -> default local dev (npm run dev)
#   .env.staging.local      -> local staging profile (npm run dev:staging)
#   .env.production.local   -> local production profile (npm run dev:production)
# ============================================================

# Stripe (server-side only) — use sk_test_... for staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional safety mode for validating Stripe config without creating live checkouts.
# Accepted true values: true, 1, yes, on
CHECKOUT_DRY_RUN=false

# Stripe product prices — these differ between test and live Stripe dashboards.
# Numbering follows tier definition order in src/lib/forms/tiers.ts:
#   1 = basic (associate-equivalent)
#   2 = advanced (professional-equivalent)
#   N = any new tier appended to TIERS — see docs/DEPLOY.md Phase 7.
# Test prices: from Stripe test dashboard
# Live prices: from Stripe live dashboard
STRIPE_PRICE_1=price_replace_me
STRIPE_PRICE_2=price_replace_me
STRIPE_PRICE_1_RENEWAL=price_replace_me
STRIPE_PRICE_2_RENEWAL=price_replace_me


# Public site base URL — MUST match the deployed environment:
#   Local dev:        http://localhost:4321
#   Staging deploy:   https://remember-staging.fly.dev
#   Production deploy: https://your-domain.example
PUBLIC_APP_URL=http://localhost:4321

# Org identity (used in email subjects, bodies, From/Reply-To fallbacks)
ORG_NAME=Re:Member
SUPPORT_EMAIL=membership@example.com
ADMIN_EMAIL=admin@example.com
PUBLIC_ORG_URL=https://example.com
# Optional overrides for src/lib/staging.ts fallbacks
# STAGING_APP_URL=https://staging.example.com
# PROD_APP_URL=https://example.com

# Google Sheets (service account for webhook logging)
# Create in Google Cloud Console → IAM → Service Accounts → create key → download JSON
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# Gmail transactional email (resume-link emails)
# Use OAuth credentials created in your GCP project.
# Option A (recommended for deploys): OAuth refresh token credentials
GMAIL_SENDER_EMAIL=no-reply@example.com
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=replace_me
GMAIL_OAUTH_REFRESH_TOKEN=replace_me

# Mailgun transactional email (alternative to Gmail)
#   MAILGUN_API_KEY — private API key (starts with "key-")
#   MAILGUN_DOMAIN  — verified sending domain (e.g. "mg.example.com")
#   MAILGUN_FROM    — full From header value, e.g. "Re:Member <no-reply@mg.example.com>"
