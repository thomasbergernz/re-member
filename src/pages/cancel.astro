---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Checkout cancelled">
  <section class="bg-white border border-gray-200 rounded-xl p-4">
    <h1 class="text-2xl sm:text-4xl font-bold mb-1">Checkout cancelled</h1>
    <p class="text-gray-600 m-0">
      No payment was taken. You can start again when ready.
    </p>
    <p class="mt-4">
      <a href="/" class="text-blue-600 hover:text-blue-700 font-semibold">Back to membership plans</a>
    </p>
  </section>
</BaseLayout>
