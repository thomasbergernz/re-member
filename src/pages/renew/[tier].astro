---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FieldRenderer from "../../lib/forms/render/FieldRenderer.astro";
import Step from "../../lib/forms/render/Step.astro";
import { schema as renewBasicSchema } from "../../lib/forms/schemas/renewBasic";
import renewBasicContent from "../../lib/forms/schemas/renewBasic.content.json";
import { schema as renewAdvancedSchema } from "../../lib/forms/schemas/renewAdvanced";
import renewAdvancedContent from "../../lib/forms/schemas/renewAdvanced.content.json";
import { listTiers, getTier } from "../../lib/forms/tiers";

// Per-tier schema registry. Phase B wired associate; Phase G adds professional.
// Each tier loads its TS schema + sibling .content.json synchronously (Astro
// frontmatter is server-side).
const TIER_SCHEMAS = {
  basic: { schema: renewBasicSchema, content: renewBasicContent },
  advanced: { schema: renewAdvancedSchema, content: renewAdvancedContent },
} as const;

const { tier } = Astro.params;
if (!tier || !(tier in TIER_SCHEMAS)) {
  const knownSlugs = listTiers().map((t) => t.slug).join(", ");
  return new Response(
    `Unknown renewal tier: ${tier}. Known tiers: ${knownSlugs}`,
    { status: 404 },
  );
}

const tierConfig = getTier(tier);
const { schema, content } = TIER_SCHEMAS[tier as keyof typeof TIER_SCHEMAS];

const url = Astro.url;
const yearParam = url.searchParams.get("year") ?? String(new Date().getFullYear());
const yearNum = Number.parseInt(yearParam, 10);
const yearDisplay = Number.isFinite(yearNum) && yearNum >= 2024 && yearNum <= 2100 ? yearNum : new Date().getFullYear();

// Server-side pre-fill from URL params (cancel URL passes these back). Fields
// not in the schema (e.g. `phone` for associate) are ignored harmlessly by
// FieldRenderer (no matching name) and by the handler (coerced to "" / []).
const initialValues: Record<string, unknown> = {
  firstName: url.searchParams.get("firstName") ?? "",
  lastName: url.searchParams.get("lastName") ?? "",
  email: url.searchParams.get("email") ?? "",
  phone: url.searchParams.get("phone") ?? "",
  year: yearDisplay,
  pdEntries: [],
};
---

<BaseLayout title={`${tierConfig.label} Renewal — ${yearDisplay}`}>
  <div class="max-w-2xl mx-auto p-4 sm:p-8">
    <header class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{content.title}</h1>
      <p class="text-gray-600">{content.description} {yearDisplay}.</p>
    </header>

    <form id="renew-form" data-schema-driven data-schema-id={schema.id} novalidate>
      {schema.steps.map((step) => (
        <Step step={step} content={content} values={initialValues} />
      ))}

      <p class="text-xs text-gray-500 mt-2">
        Renewal year: <span id="year-display" class="font-semibold">{yearDisplay}</span>
      </p>

      <div id="error-banner" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
        <p id="error-message" class="text-amber-800"></p>
      </div>

      <button id="pay-btn" type="button"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg flex items-center justify-center gap-2">
        <span id="pay-spinner" class="hidden w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
        <span id="pay-btn-label">{content.submitLabel}</span>
      </button>
    </form>
  </div>

  <script define:vars={{ tier }}>
    const payBtn = document.getElementById("pay-btn");
    const paySpinner = document.getElementById("pay-spinner");
    const payLabel = document.getElementById("pay-btn-label");
    const errorBanner = document.getElementById("error-banner");
    const errorMessage = document.getElementById("error-message");
    const form = document.getElementById("renew-form");
    const originalLabel = payLabel.textContent;

    function showError(msg) {
      errorMessage.textContent = msg;
      errorBanner.classList.remove("hidden");
      errorBanner.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    function setLoading(loading) {
      payBtn.disabled = loading;
      payBtn.classList.toggle("opacity-70", loading);
      payBtn.classList.toggle("cursor-not-allowed", loading);
      paySpinner.classList.toggle("hidden", !loading);
      payLabel.textContent = loading ? "Loading…" : originalLabel;
    }

    function readPayload() {
      const data = new FormData(form);
      const yearText = document.getElementById("year-display").textContent ?? "";
      const out = {};
      data.forEach((v, k) => { out[k] = v; });
      out.year = Number(yearText);
      return out;
    }

    async function postCheckout(payload) {
      return fetch(`/api/renew/checkout/${tier}`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
    }

    payBtn.addEventListener("click", async () => {
      errorBanner.classList.add("hidden");
      const payload = readPayload();
      if (!payload.firstName || !payload.lastName || !payload.email || !payload.year) {
        showError("All fields required.");
        return;
      }
      setLoading(true);
      try {
        let res = await postCheckout(payload);
        let json = await res.json();
        if (!res.ok) {
          if (json.code === "SHEET_WRITE_FAILED" && json.retryable) {
            for (let attempt = 1; attempt <= 2; attempt++) {
              await new Promise((r) => setTimeout(r, 1500 * attempt));
              try {
                res = await postCheckout(payload);
                json = await res.json();
                if (res.ok && json.url) {
                  window.location.assign(json.url);
                  return;
                }
              } catch (_) { /* fall through */ }
            }
            showError("Network issue with Google Sheets. Please try again in a minute.");
            setLoading(false);
            return;
          }
          showError(json.error ?? `Error ${res.status}`);
          setLoading(false);
          return;
        }
        if (json.dryRun) {
          showError(`Dry-run: price validated (${json.priceId}).`);
          setLoading(false);
          return;
        }
        window.location.assign(json.url);
      } catch (_) {
        showError("Network error. Please try again.");
        setLoading(false);
      }
    });
  </script>

  <script id="form-schema" type="application/json" set:html={JSON.stringify(schema)}></script>

  <script>
    import { mount } from "../../lib/forms/render/form-client";
    const form = document.querySelector("form[data-schema-driven]");
    const schemaEl = document.getElementById("form-schema");
    if (form?.parentElement && schemaEl?.textContent) {
      try {
        const schema = JSON.parse(schemaEl.textContent);
        mount(form.parentElement, { schema });
      } catch (err) {
        console.warn("[renew] schema parse failed", err);
      }
    }
  </script>
</BaseLayout>