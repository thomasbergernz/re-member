---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Subscription complete">
  <section class="bg-white border border-gray-200 rounded-xl p-4">
    <h1 class="text-2xl sm:text-4xl font-bold mb-1">Subscription confirmed</h1>
    <p class="text-gray-600 m-0" id="message">
      Loading...
    </p>
    <div id="next-steps" class="hidden mt-4">
      <p id="form-link-text" class="m-0 mb-2"></p>
      <a id="form-link" href="#" class="text-blue-600 hover:text-blue-700 font-semibold"></a>
    </div>
    <div id="countdown" class="hidden mt-3 text-gray-600 text-sm"></div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get("session_id");
  const messageEl = document.querySelector<HTMLParagraphElement>("#message");
  const nextStepsEl = document.querySelector<HTMLDivElement>("#next-steps");
  const formLinkText = document.querySelector<HTMLParagraphElement>("#form-link-text");
  const formLinkEl = document.querySelector<HTMLAnchorElement>("#form-link");
  const countdownEl = document.querySelector<HTMLDivElement>("#countdown");

  if (!sessionId) {
    messageEl!.textContent = "No session found. If you completed checkout, please contact us.";
    throw new Error("No session_id");
  }

  try {
    const res = await fetch(`/api/session-info?session_id=${sessionId}`);
    const data = await res.json();

    if (!res.ok || data.error) {
      messageEl!.textContent = "Could not load session details. Please contact us.";
      throw new Error(data.error || "Session fetch failed");
    }

    const plan = data.plan;
    const name = data.firstName ? ` ${data.firstName}` : "";

    if (plan === "professional") {
      messageEl!.textContent = `Thank you${name}! Your Professional Membership payment was successful.`;
      formLinkText!.textContent = "Next step:";
      formLinkEl!.textContent = "Complete your Professional Membership application";
      formLinkEl!.href = "https://www.example.com/professional-membership";
      nextStepsEl!.classList.remove("hidden");
      countdownEl!.classList.remove("hidden");
      countdownEl!.textContent = "Redirecting in 4 seconds...";
      let count = 4;
      const timer = setInterval(() => {
        count--;
        if (count <= 0) {
          clearInterval(timer);
          window.location.href = "https://www.example.com/professional-membership";
        } else {
          countdownEl!.textContent = `Redirecting in ${count} second${count === 1 ? "" : "s"}...`;
        }
      }, 1000);
    } else {
      messageEl!.textContent = "Thank you. Your subscription checkout completed successfully.";
      formLinkText!.textContent = "Return to the Re:Member website:";
      formLinkEl!.textContent = "example.com/membership";
      formLinkEl!.href = "https://www.example.com/membership";
      nextStepsEl!.classList.remove("hidden");
    }
  } catch {
    messageEl!.textContent = "Thank you. Your subscription checkout completed successfully.";
    formLinkText!.textContent = "Return to the Re:Member website:";
    formLinkEl!.textContent = "example.com/membership";
    formLinkEl!.href = "https://www.example.com/membership";
    nextStepsEl!.classList.remove("hidden");
  }
</script>
