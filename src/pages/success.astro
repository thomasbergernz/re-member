---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Subscription complete">
  <section class="card">
    <h1 class="headline">Subscription confirmed</h1>
    <p class="sub">
      Thank you. Your subscription checkout completed successfully.
    </p>
    <p style="margin-top: 1rem;">
      <a href="https://www.eldaa.org.nz/membership" style="color: var(--accent); font-weight: 600;">Return to membership page</a>
    </p>
  </section>
</BaseLayout>
