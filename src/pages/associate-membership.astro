---
import BaseLayout from "../layouts/BaseLayout.astro";

const sessionId = Astro.url.searchParams.get("session_id");
---

<BaseLayout
  title="Associate Membership — Welcome"
  description="Welcome to ELDAA as an Associate Member."
>
  <section class="bg-white border border-gray-200 rounded-xl p-4">
    <h1 class="text-2xl sm:text-4xl font-bold mb-1">Application Submitted</h1>
    <p class="text-gray-600 m-0">
      Thank you for applying for Associate Membership with ELDAA.
    </p>

    {sessionId && (
      <p class="mt-4 text-gray-600 text-sm">
        Reference: {sessionId}
      </p>
    )}

    <div class="mt-6 p-4 bg-emerald-50 rounded-lg border border-emerald-700">
      <p class="text-emerald-700 font-semibold m-0">
        Thanks for joining ELDAA as an Associate Member.
      </p>
      <p class="text-gray-600 mt-2 mb-0">
        If you requested having your name published on our site, this will be done soon. Meanwhile, please go to our welcome documents here: <a href="https://drive.google.com/drive/folders/18tdqgcQ97Z1mVLQU7Z3mToRI2UPGZydm?usp=sharing" class="text-blue-600 hover:text-blue-700">ELDAA Associate Member Welcome Documents</a>
      </p>
    </div>

    <p class="mt-6">
      <a href="https://eldaa.org.nz" class="text-blue-600 hover:text-blue-700">Return to ELDAA website</a>
    </p>
  </section>
</BaseLayout>