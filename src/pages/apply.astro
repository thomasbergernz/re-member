---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Associate Membership Application"
  description="Apply for Associate Membership with ELDAA."
>
  <section class="bg-white border border-gray-200 rounded-xl p-4 sm:p-6">
    <h1 class="text-2xl sm:text-4xl font-bold mb-1">Associate Membership Application</h1>
    <p class="text-gray-600 m-0">
      Complete this short application, then continue to secure payment.
    </p>
  </section>

  <section class="bg-white border border-gray-200 rounded-xl p-4 sm:p-6 mt-4">
    <h2 class="m-0 text-xl font-semibold">Personal Information</h2>
    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="firstName" class="block font-semibold mb-1.5">First Name *</label>
        <input
          id="firstName"
          name="firstName"
          type="text"
          autocomplete="given-name"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
      <div>
        <label for="lastName" class="block font-semibold mb-1.5">Last Name *</label>
        <input
          id="lastName"
          name="lastName"
          type="text"
          autocomplete="family-name"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
    </div>

    <div class="mt-4">
      <label for="email" class="block font-semibold mb-1.5">Email *</label>
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
      />
    </div>

    <div class="mt-4">
      <label for="fullAddress" class="block font-semibold mb-1.5">Full Address *</label>
      <input
        id="fullAddress"
        name="fullAddress"
        type="text"
        autocomplete="street-address"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
      />
    </div>

    <div class="mt-4">
      <label for="postalAddress" class="block font-semibold mb-1.5">Postal Address (if different)</label>
      <input
        id="postalAddress"
        name="postalAddress"
        type="text"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
      />
    </div>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="phone" class="block font-semibold mb-1.5">Phone Number *</label>
        <input
          id="phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
      <div>
        <label for="businessName" class="block font-semibold mb-1.5">Business Name (if applicable)</label>
        <input
          id="businessName"
          name="businessName"
          type="text"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border border-gray-200 rounded-xl p-4 sm:p-6 mt-4">
    <h2 class="m-0 text-xl font-semibold">Additional Information</h2>

    <div class="mt-4">
      <label for="interestJoining" class="block font-semibold mb-1.5">What is your interest in joining ELDAA? *</label>
      <textarea
        id="interestJoining"
        name="interestJoining"
        rows="4"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base resize-y"
      ></textarea>
    </div>

    <div class="mt-4">
      <label for="trainingDetails" class="block font-semibold mb-1.5">Are you training to be an End of Life Doula? If yes, with which organisation and expected completion date? *</label>
      <textarea
        id="trainingDetails"
        name="trainingDetails"
        rows="4"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base resize-y"
      ></textarea>
    </div>

    <fieldset class="mt-4 border border-gray-200 rounded-lg p-3">
      <legend class="px-1 font-semibold">Would you like to be listed on our Associate Members page? *</legend>
      <div class="mt-2 flex gap-6">
        <label class="inline-flex items-center gap-2">
          <input type="radio" name="listOnPage" value="yes" />
          <span>Yes</span>
        </label>
        <label class="inline-flex items-center gap-2">
          <input type="radio" name="listOnPage" value="no" />
          <span>No</span>
        </label>
      </div>
    </fieldset>

    <div class="mt-4">
      <label for="listingDetails" class="block font-semibold mb-1.5">If yes, please provide your name, business name, and location for publication.</label>
      <textarea
        id="listingDetails"
        name="listingDetails"
        rows="3"
        class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base resize-y"
      ></textarea>
    </div>
  </section>

  <section class="bg-white border border-gray-200 rounded-xl p-4 sm:p-6 mt-4">
    <h2 class="m-0 text-xl font-semibold">Declaration</h2>
    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="signature" class="block font-semibold mb-1.5">Your Signature (type full name) *</label>
        <input
          id="signature"
          name="signature"
          type="text"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
      <div>
        <label for="applicationDate" class="block font-semibold mb-1.5">Today's Date *</label>
        <input
          id="applicationDate"
          name="applicationDate"
          type="date"
          class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-base"
        />
      </div>
    </div>
  </section>

  <section class="mt-4 mb-2">
    <button
      id="submit-btn"
      class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg w-full sm:w-auto"
    >
      Submit Application
    </button>
    <p id="status" class="mt-3 min-h-6 text-amber-800" aria-live="polite"></p>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);

  const prefill = (id: string, key: string) => {
    const el = document.querySelector(id);
    if (el instanceof HTMLInputElement && params.has(key)) {
      el.value = params.get(key) ?? "";
    }
  };

  prefill("#firstName", "firstName");
  prefill("#lastName", "lastName");
  prefill("#phone", "phone");
  prefill("#email", "email");

  const dateInput = document.querySelector<HTMLInputElement>("#applicationDate");
  if (dateInput && !dateInput.value) {
    dateInput.valueAsDate = new Date();
  }

  const statusEl = document.querySelector("#status");
  const submitBtn = document.querySelector("#submit-btn");

  const firstNameInput = document.querySelector("#firstName");
  const lastNameInput = document.querySelector("#lastName");
  const phoneInput = document.querySelector("#phone");
  const emailInput = document.querySelector("#email");
  const fullAddressInput = document.querySelector("#fullAddress");
  const interestJoiningInput = document.querySelector("#interestJoining");
  const trainingDetailsInput = document.querySelector("#trainingDetails");
  const listingDetailsInput = document.querySelector("#listingDetails");
  const signatureInput = document.querySelector("#signature");
  const applicationDateInput = document.querySelector("#applicationDate");

  const getVal = (el: Element | null) => {
    if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
      return el.value.trim();
    }
    return "";
  };

  const getListingChoice = () => {
    const selected = document.querySelector("input[name=\"listOnPage\"]:checked");
    return selected instanceof HTMLInputElement ? selected.value : "";
  };

  const setStatus = (message: string, type: "info" | "error" | "ok" = "info") => {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.className = type === "error"
      ? "mt-3 min-h-6 text-amber-800"
      : type === "ok"
        ? "mt-3 min-h-6 text-emerald-700"
        : "mt-3 min-h-6";
  };

  const setLoading = (isLoading: boolean) => {
    if (!(submitBtn instanceof HTMLButtonElement)) return;
    submitBtn.disabled = isLoading;
    submitBtn.textContent = isLoading ? "Redirecting to Checkout..." : "Submit Application";
  };

  const validate = () => {
    if (!getVal(firstNameInput)) { setStatus("Enter your first name.", "error"); return false; }
    if (!getVal(lastNameInput)) { setStatus("Enter your last name.", "error"); return false; }
    if (!getVal(emailInput)) { setStatus("Enter your email address.", "error"); return false; }
    if (!getVal(phoneInput)) { setStatus("Enter your phone number.", "error"); return false; }
    if (!getVal(fullAddressInput)) { setStatus("Enter your full address.", "error"); return false; }
    if (!getVal(interestJoiningInput)) { setStatus("Tell us your interest in joining ELDAA.", "error"); return false; }
    if (!getVal(trainingDetailsInput)) { setStatus("Complete the End of Life Doula training question.", "error"); return false; }

    const listingChoice = getListingChoice();
    if (!listingChoice) { setStatus("Choose whether you want to be listed on the Associate Members page.", "error"); return false; }
    if (listingChoice === "yes" && !getVal(listingDetailsInput)) {
      setStatus("Provide listing details for publication.", "error");
      return false;
    }

    if (!getVal(signatureInput)) { setStatus("Enter your signature.", "error"); return false; }
    if (!getVal(applicationDateInput)) { setStatus("Enter today's date.", "error"); return false; }

    return true;
  };

  submitBtn?.addEventListener("click", async () => {
    if (!validate()) return;

    const payload = {
      plan: "associate",
      applicationSource: "apply",
      firstName: getVal(firstNameInput),
      lastName: getVal(lastNameInput),
      phone: getVal(phoneInput),
      email: getVal(emailInput),
      fullAddress: getVal(fullAddressInput),
      postalAddress: getVal(document.querySelector("#postalAddress")),
      businessName: getVal(document.querySelector("#businessName")),
      interestJoining: getVal(interestJoiningInput),
      trainingDetails: getVal(trainingDetailsInput),
      listOnPage: getListingChoice(),
      listingDetails: getVal(listingDetailsInput),
      signature: getVal(signatureInput),
      applicationDate: getVal(applicationDateInput),
    };

    setLoading(true);
    setStatus("Creating your secure checkout session...");

    try {
      const response = await fetch("/api/create-checkout-session", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const data = await response.json();
      if (data.dryRun) {
        setLoading(false);
        setStatus(data.message || "Dry run passed. Stripe configuration validated.", "ok");
        return;
      }

      if (!response.ok || !data.url) {
        throw new Error(data.error || "Checkout session creation failed.");
      }

      window.location.assign(data.url);
    } catch (error) {
      setLoading(false);
      setStatus(error instanceof Error ? error.message : "Checkout error.", "error");
    }
  });
</script>
