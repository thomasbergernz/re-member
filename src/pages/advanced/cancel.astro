---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Checkout cancelled">
  <section class="bg-white border border-gray-200 rounded-xl p-4">
    <h1 class="text-2xl sm:text-4xl font-bold mb-1">Checkout cancelled</h1>
    <p class="text-gray-600 m-0">
      Your Professional Membership checkout was not completed.
      No charges have been made.
    </p>
    <p class="mt-4">
      <a href="/advanced/apply" class="text-blue-600 hover:text-blue-700 font-semibold">Try again</a>
    </p>
  </section>
</BaseLayout>
