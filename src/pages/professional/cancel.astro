---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Checkout cancelled">
  <section class="card">
    <h1 class="headline">Checkout cancelled</h1>
    <p class="sub">
      Your Professional Membership checkout was not completed.
      No charges have been made.
    </p>
    <p style="margin-top: 1rem;">
      <a href="/professional" style="color: var(--accent); font-weight: 600;">Try again</a>
    </p>
  </section>
</BaseLayout>
