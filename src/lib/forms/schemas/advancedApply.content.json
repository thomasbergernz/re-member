{
  "title": "Professional Membership Application",
  "description": "Apply for JimuMember Professional Membership.",
  "steps": {
    "about": {
      "title": "About You",
      "fields": {
        "firstName": {
          "label": "First name",
          "placeholder": "Jane"
        },
        "lastName": {
          "label": "Last name",
          "placeholder": "Doe"
        },
        "dateOfBirth": {
          "label": "Date of Birth",
          "placeholder": "DD/MM/YYYY"
        },
        "ethnicity": {
          "label": "Ethnicity",
          "help": "Optional — used for equity reporting"
        },
        "address": {
          "label": "Physical address"
        },
        "postalAddress": {
          "label": "Postal address",
          "help": "If different from above"
        },
        "phone": {
          "label": "Phone"
        },
        "email": {
          "label": "Email"
        },
        "businessName": {
          "label": "Business name"
        },
        "website": {
          "label": "Website",
          "placeholder": "https://"
        }
      }
    },
    "training": {
      "title": "Training & Education",
      "fields": {
        "qualifications": {
          "label": "Qualifications",
          "help": "Add each course or certificate separately."
        },
        "qualifications.name": {
          "label": "Course name"
        },
        "qualifications.provider": {
          "label": "Provider"
        },
        "qualifications.year": {
          "label": "Year completed"
        }
      }
    },
    "experience": {
      "title": "Professional Experience",
      "fields": {
        "rows": {
          "label": "Experience rows"
        },
        "rows.role": {
          "label": "Role"
        },
        "rows.skills": {
          "label": "Skills"
        },
        "rows.description": {
          "label": "Description"
        },
        "example1": {
          "label": "Example narrative 1",
          "help": "Describe a meaningful client engagement."
        },
        "example2": {
          "label": "Example narrative 2"
        },
        "example3": {
          "label": "Example narrative 3"
        }
      }
    },
    "furtherRequirements": {
      "title": "Further Requirements",
      "fields": {
        "furtherRequirements": {
          "label": "Further requirements",
          "options": {
            "agreeMemberServices": "Do you agree to actively provide Member Services?",
            "agreeInterview": "Do you agree to an interview by one or more committee members?",
            "commitProfessionalDev": "Do you agree to submit proof of up to 10 hours of professional development each year?",
            "willInsurance": "Will you take out professional indemnity insurance? (recommended)",
            "listDirectory": "Do you wish to be listed as a practicing member in our public directory?",
            "provideCriminalCheck": "Are you willing to provide a current criminal background check?",
            "attendMeetings": "Are you willing to attend regular JimuMember meetings and events, and engage with and support your local JimuMember community?",
            "workRemotely": "Are you willing to work remotely where there is no other available Professional Member in a Client's area?"
          }
        }
      }
    },
    "competencies": {
      "title": "Professional Standards & Core Competencies",
      "fields": {
        "coreCompetencies": {
          "label": "Core competencies",
          "help": "Tick the competencies you are confident in providing. Stable column order — reordering breaks the production sheet contract.",
          "options": {
            "effectiveCommunication": "Effective Communication Skills",
            "advocacyEmpowerment": "Advocacy & Empowerment",
            "culturalCommunityDiversity": "Understanding of Cultural & Community Diversity",
            "showsInitiative": "Shows initiative",
            "compassionatePresence": "Compassionate Presence",
            "ongoingEducation": "Ongoing Education & Development",
            "selfCareBoundaries": "Self-Care & Professional Boundaries",
            "coreSubjectKnowledge": "Core Subject-Matter Knowledge",
            "businessAcumen": "Business acumen",
            "networkingReferrals": "Networking & Referrals",
            "holisticSupport": "Holistic support",
            "clientJourneyAdvocacy": "Client journey advocacy and empowerment",
            "longTermPlanningReview": "Long-Term Planning & Review",
            "structuredAdvancePlanning": "Structured Advance Planning",
            "transitionPlanningSupport": "Transition Planning & Support",
            "practicalAssistance": "Practical Assistance",
            "milestoneEventPlanning": "Milestone & Event Planning",
            "handoverClosingPractices": "Handover & Closing Practices",
            "transitionSupportAwareness": "Transition & Support Awareness",
            "interdisciplinaryCollaboration": "Interdisciplinary Collaboration",
            "mentorship": "Mentorship"
          }
        }
      }
    },
    "referees": {
      "title": "Referees",
      "fields": {
        "referees": {
          "label": "Two referees"
        },
        "referee1Name": {
          "label": "Referee 1 — name"
        },
        "referee1Role": {
          "label": "Referee 1 — role"
        },
        "referee1Email": {
          "label": "Referee 1 — email"
        },
        "referee1Phone": {
          "label": "Referee 1 — phone"
        },
        "referee2Name": {
          "label": "Referee 2 — name"
        },
        "referee2Role": {
          "label": "Referee 2 — role"
        },
        "referee2Email": {
          "label": "Referee 2 — email"
        },
        "referee2Phone": {
          "label": "Referee 2 — phone"
        }
      }
    },
    "declarations": {
      "title": "Declarations",
      "fields": {
        "accuracy": {
          "label": "I confirm that the information I have provided is true and accurate to the best of my knowledge."
        },
        "ethics": {
          "label": "I agree to abide by the JimuMember Code of Ethics and Scope of Practice."
        },
        "scope": {
          "label": "I understand and will work within the JimuMember Scope of Practice."
        },
        "memberServices": {
          "label": "I agree to actively provide Member Services."
        },
        "interview": {
          "label": "I agree to an interview by one or more committee members."
        },
        "professionalDev": {
          "label": "I agree to submit proof of up to 10 hours of professional development each year."
        },
        "criminalCheck": {
          "label": "I am willing to provide a current criminal background check."
        },
        "meetings": {
          "label": "I am willing to attend regular JimuMember meetings and events, and engage with and support my local JimuMember community."
        }
      }
    },
    "uploads": {
      "title": "Document Upload",
      "fields": {}
    }
  },
  "uploads": {
    "docTypes": {
      "training": "Certificates of training",
      "ethics": "Code of Ethics & Scope of Practice",
      "criminal": "Criminal background check",
      "planning_cert": "Advance Planning Certification",
      "specialist_training": "Specialist Online Training Module",
      "fundamentals": "Fundamentals of Practice",
      "insurance": "Professional indemnity insurance"
    }
  }
}
