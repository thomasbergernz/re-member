---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Membership checkout — apply, renew, and manage your organisation membership.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="font-sans text-gray-800 bg-gradient-to-b from-gray-50 to-indigo-100 min-h-screen">
    <main class="w-full max-w-5xl mx-auto px-4 py-4">
      <slot />
    </main>
  </body>
</html>
